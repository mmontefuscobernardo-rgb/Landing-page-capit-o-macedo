rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net - block all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Leads collection rules
    match /leads/{leadId} {
      // Direct client reads and writes are blocked for ultimate security.
      // All secure data flows directly through our centralized Express API controller proxy.
      allow read, write: if false;
    }
  }
}
